{
  "name": "video-comparator",
  "version": "1.1.1",
  "description": "Professional side-by-side video comparison tool.",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "build:linux": "npm run build && electron-builder --linux --x64",
    "build:arm64": "npm run build && electron-builder --linux --arm64",
    "build:win": "npm run build && electron-builder --win"
  },
  "author": "Pulto",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "build": {
    "appId": "com.video-comparator.app",
    "productName": "Video-Comparator",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "main.js",
      "package.json",
      "dist/**/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Video"
    },
    "asar": true
  }
}
